<div class="container py-3">
  <div class="card mb-4">
    <div class="card-header py-3">
      <strong class="ls-display fs-5">Split a Check</strong>
    </div>
    <div class="card-body">
      <% if @check.errors.any? %>
        <div class="alert alert-danger">
          <ul class="mb-0">
            <% @check.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <%= form_with url: checks_path, method: :post, local: true, multipart: true do |f| %>
        <div class="mb-3">
          <%= f.label :receipt_images, "Receipt Photos", class: "form-label" %>
          <%= f.file_field :receipt_images, multiple: true, class: "form-control", accept: "image/*" %>
          <div class="form-text">Upload one or more images of your receipt</div>
        </div>

        <div class="mb-3">
          <%= f.label :participant_names, "Who's splitting?", class: "form-label" %>
          <%= f.text_area :participant_names, class: "form-control", rows: 3, placeholder: "Alice\nBob\nCarol", data: { controller: "autogrow" } %>
          <div class="form-text">Enter names separated by newlines, spaces, periods, or commas</div>
        </div>

        <%= f.button class: "sticker primary w-100 justify-content-center" do %>
          <i class="bi bi-stars"></i> Parse Receipt
        <% end %>
      <% end %>
    </div>
  </div>

  <% if @all_checks.present? %>
    <div class="card mb-4">
      <div class="card-header py-3">
        <strong class="ls-display fs-5">All Checks</strong>
      </div>
      <ul class="list-group list-group-flush">
        <% @all_checks.each do |check| %>
          <%= link_to check, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>
            <div>
              <div class="ls-display fs-5"><%= check.restaurant_name || "Untitled Check" %></div>
              <% if check.participants.any? %>
                <div class="text-muted small"><%= check.participants.order(:name).pluck(:name).to_sentence %></div>
              <% end %>
            </div>
            <div class="text-end">
              <div class="ls-num"><%= check.currency_symbol %><%= number_with_precision(check.grand_total, precision: 2) %></div>
              <% if check.billed_on.present? %>
                <div class="text-muted small"><%= check.billed_on.strftime("%b %d, %Y") %></div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if @recent_checks.any? %>
    <div class="card">
      <div class="card-header py-3">
        <strong class="ls-display fs-5">Recently Visited</strong>
      </div>
      <ul class="list-group list-group-flush">
        <% @recent_checks.each do |check| %>
          <%= link_to check, class: "list-group-item list-group-item-action d-flex justify-content-between align-items-start" do %>
            <div>
              <div class="ls-display fs-5"><%= check.restaurant_name || "Untitled Check" %></div>
              <% if check.participants.any? %>
                <div class="text-muted small"><%= check.participants.order(:name).pluck(:name).to_sentence %></div>
              <% end %>
            </div>
            <div class="text-end">
              <div class="ls-num"><%= check.currency_symbol %><%= number_with_precision(check.grand_total, precision: 2) %></div>
              <% if check.billed_on.present? %>
                <div class="text-muted small"><%= check.billed_on.strftime("%b %d, %Y") %></div>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </ul>
    </div>
  <% end %>
</div>
