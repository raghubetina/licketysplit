<%# Accepts: check (required), open (optional, defaults to false — parsing renders it open since that's the sharing moment) %>

<%= tag.details id: "share_details", class: "ls-share mb-3", open: local_assigns[:open], data: { turbo_permanent: true } do %>
  <summary class="sticker compact">
    <i class="bi bi-qr-code-scan"></i> Share with the table
  </summary>
  <div class="ls-share-body">
    <div class="mx-auto" style="max-width: 280px;">
      <%= qr_code_svg(check_url(check), level: :m) %>
    </div>
    <div class="text-muted small mt-2"><i class="bi bi-qr-code-scan"></i> Scan to join</div>
    <button class="sticker primary w-100 mt-2 justify-content-center"
            data-controller="clipboard"
            data-clipboard-text-value="<%= check_url(check) %>"
            data-action="clipboard#copy">
      <i class="bi bi-clipboard"></i> Copy link
    </button>
  </div>
<% end %>
