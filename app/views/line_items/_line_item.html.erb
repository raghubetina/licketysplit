<%# Accepts: line_item (required), check (optional - will be derived from line_item if not provided), participants (optional - will be queried if not provided), show_zero_items (optional - defaults to true), show_assignment (optional - defaults to true; false hides assignment UI, e.g. in even-split mode) %>
<% check ||= line_item.check %>
<% participants ||= check.participants.order(:name) %>
<% show_zero_items = local_assigns.fetch(:show_zero_items, true) %>
<% show_assignment = local_assigns.fetch(:show_assignment, true) %>

<%
  assigned_ids = line_item.participant_ids
  single_owner = (assigned_ids.size == 1) ? participants.detect { |p| p.id == assigned_ids.first } : nil
  tint_class = if !show_assignment
    nil
  elsif single_owner
    "ls-item-tinted #{participant_color_class(single_owner)}"
  elsif assigned_ids.empty?
    "ls-item-unassigned"
  end
%>
<li id="<%= dom_id(line_item) %>" class="list-group-item py-3 px-3 d-flex flex-column gap-3 <%= tint_class %>" data-turbo-refresh-animate data-turbo-refresh-version="<%= line_item.cache_key_with_version %>">
  <%= render partial: "line_items/line_item_content", locals: { line_item: line_item, check: check } %>

  <% line_item.addons.each do |addon| %>
    <% next if !show_zero_items && addon.total_price == 0 %>
    <%= render partial: "addons/addon", locals: { addon: addon, line_item: line_item } %>
  <% end %>

  <% if show_assignment %>
    <%= render partial: "line_items/participant_toggles", locals: { line_item: line_item, check: check, participants: participants } %>
  <% end %>
</li>
